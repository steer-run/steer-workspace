<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================
         REVISAR antes de publicar (heurísticas inciertas):
           - Owner UID:GID de 'metube' (imagen ghcr.io/alexta69/metube) desconocido → DEFAULT 1000:1000, verificar.
           - Imagen en 'latest': fijá un tag estable (variable selection) antes de producción.
