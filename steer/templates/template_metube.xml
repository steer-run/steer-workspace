    <record id="template_metube" model="service.template">
        <field name="name">MeTube</field>
        <field name="code">metube</field>
        <field name="service_code">metube</field>
        <field name="version">latest</field>
        <field name="description">MeTube is a self-hosted web interface for yt-dlp that lets you download videos and audio from YouTube and hundreds of other sites straight from your browser.</field>
        <field name="rich_description"><![CDATA[<div class="agz-app-desc">
  <p class="agz-app-lead">MeTube is a self-hosted web interface for yt-dlp that lets you download videos and audio from YouTube and hundreds of other sites straight from your browser.</p>
  <p>It wraps the powerful yt-dlp command-line downloader in a clean, queue-based web UI, so you can grab media without touching a terminal. Downloads run on your own server and land in a directory you control, making it a private alternative to ad-laden online download sites. It is aimed at self-hosters and home-lab users who want a simple, always-available downloader.</p>
  <h6 class="agz-app-subhead">Key features</h6>
  <ul class="agz-app-feats">
    <li>Browser-based UI for yt-dlp with a live download queue and progress tracking</li>
    <li>Download video, audio-only, captions and thumbnails in selectable formats and quality</li>
    <li>Batch download of full playlists and channels</li>
    <li>Subscriptions that periodically check channels/playlists and auto-queue new uploads</li>
    <li>Configurable behaviour via global options, named presets and per-download overrides</li>
    <li>Official Docker images with automated nightly yt-dlp updates, optional basic auth and reverse-proxy support</li>
  </ul>
  <h6 class="agz-app-subhead">Best for</h6>
  <p>Self-hosters and home-lab users who want a private, browser-accessible tool to archive and download online video and audio for offline viewing or personal media libraries.</p>
</div>]]></field>
        <field name="category">media</field>
        <field name="is_web_app">True</field>
        <field name="requires_database">False</field>
        <field name="requires_backup">True</field>
        <field name="backup_mode">standard</field>
        <field name="image" type="base64" file="agz_infra_templates/static/img/templates/metube.png"/>
        <field name="tag_ids" eval="[Command.set([ref('agz_infra_suite.tag_self_hosted'), ref('agz_infra_suite.tag_media'), ref('agz_infra_suite.tag_privacy')])]"/>
        <field name="website_url">https://github.com/alexta69/metube</field>
        <field name="documentation_url">https://github.com/alexta69/metube/wiki</field>
        <field name="source_url">https://github.com/alexta69/metube</field>
        <field name="docker_compose_template"><![CDATA[services:
  metube:
    image: ghcr.io/alexta69/metube
    restart: unless-stopped
    ports:
    - '{{ PORT_HTTP }}:8081'
    volumes:
    - ../files/downloads:/downloads
    container_name: '{{ INSTANCE_CODE }}'
    networks:
    - internal
    - agz-proxy-network
networks:
  internal:
    driver: bridge
  agz-proxy-network:
    external: true
]]></field>
