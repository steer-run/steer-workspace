        <field name="docker_compose_template"><![CDATA[services:
  webapp:
    image: ghcr.io/triggerdotdev/trigger.dev:${TRIGGER_IMAGE_TAG:-v3}
    restart: ${RESTART_POLICY:-unless-stopped}
    env_file:
    - .env
    environment:
      LOGIN_ORIGIN: ${TRIGGER_PROTOCOL:-http}://${TRIGGER_DOMAIN:-localhost:3040}
      APP_ORIGIN: ${TRIGGER_PROTOCOL:-http}://${TRIGGER_DOMAIN:-localhost:3040}
      DEV_OTEL_EXPORTER_OTLP_ENDPOINT: ${TRIGGER_PROTOCOL:-http}://${TRIGGER_DOMAIN:-localhost:3040}/otel
      ELECTRIC_ORIGIN: http://electric:3000
    ports:
    - '{{ PORT_HTTP }}:3000'
    depends_on:
    - postgres
    - redis
    networks:
    - internal
    - agz-proxy-network
    container_name: '{{ INSTANCE_CODE }}'
  postgres:
    image: postgres:${POSTGRES_IMAGE_TAG:-16}
    restart: ${RESTART_POLICY:-unless-stopped}
    volumes:
    - ./postgres_data:/var/lib/postgresql/data/
    env_file:
    - .env
    networks:
    - internal
    ports:
    - 5432
    command:
    - -c
    - wal_level=logical
    container_name: '{{ INSTANCE_CODE }}_postgres'
  redis:
    image: redis:${REDIS_IMAGE_TAG:-7}
    restart: ${RESTART_POLICY:-unless-stopped}
    volumes:
    - ./redis_data:/data
    networks:
    - internal
    ports:
    - 6379
    container_name: '{{ INSTANCE_CODE }}_redis'
  docker-provider:
    image: ghcr.io/triggerdotdev/provider/docker:${TRIGGER_IMAGE_TAG:-v3}
    restart: ${RESTART_POLICY:-unless-stopped}
    volumes:
    - /var/run/docker.sock:/var/run/docker.sock
    user: root
    networks:
    - internal
    depends_on:
    - webapp
    ports:
    - 9020
    env_file:
    - .env
    environment:
      PLATFORM_HOST: webapp
      PLATFORM_WS_PORT: 3030
      SECURE_CONNECTION: 'false'
      OTEL_EXPORTER_OTLP_ENDPOINT: ${TRIGGER_PROTOCOL:-http}://${TRIGGER_DOMAIN:-localhost:3040}/otel
      PLATFORM_SECRET: $PROVIDER_SECRET
    container_name: '{{ INSTANCE_CODE }}_docker_provider'
  coordinator:
    image: ghcr.io/triggerdotdev/coordinator:${TRIGGER_IMAGE_TAG:-v3}
    restart: ${RESTART_POLICY:-unless-stopped}
    volumes:
    - /var/run/docker.sock:/var/run/docker.sock
    user: root
    networks:
    - internal
    depends_on:
    - webapp
    ports:
    - 9020
    env_file:
    - .env
    environment:
      PLATFORM_HOST: webapp
      PLATFORM_WS_PORT: 3030
      SECURE_CONNECTION: 'false'
      OTEL_EXPORTER_OTLP_ENDPOINT: ${TRIGGER_PROTOCOL:-http}://${TRIGGER_DOMAIN:-localhost:3040}/otel
      PLATFORM_SECRET: $COORDINATOR_SECRET
    container_name: '{{ INSTANCE_CODE }}_coordinator'
  electric:
    image: electricsql/electric:${ELECTRIC_IMAGE_TAG:-latest}
    restart: ${RESTART_POLICY:-unless-stopped}
    environment:
      DATABASE_URL: {{ database_url }}?sslmode=disable
    networks:
    - internal
    depends_on:
    - postgres
    ports:
    - 3000
    container_name: '{{ INSTANCE_CODE }}_electric'
networks:
  internal:
    driver: bridge
  agz-proxy-network:
    external: true
]]></field>
        <field name="backup_script"><![CDATA[#!/bin/bash
set -euo pipefail
cd "$SERVICE_PATH"
# Dump consistente de PostgreSQL (servicio en marcha) → $BACKUP_DATA_DIR
docker compose exec -T postgres sh -c 'pg_dump -U "$POSTGRES_USER" -d "$POSTGRES_DB" --no-owner -Fc' \
  > "$BACKUP_DATA_DIR/db.dump"
echo "pg_dump OK ($(wc -c < "$BACKUP_DATA_DIR/db.dump") bytes)"
]]></field>
        <field name="restore_script"><![CDATA[#!/bin/bash
set -euo pipefail
cd "$SERVICE_PATH"
# Levanta solo la DB, espera readiness y restaura
docker compose up -d postgres
for i in $(seq 1 30); do
  docker compose exec -T postgres sh -c 'pg_isready -U "$POSTGRES_USER"' && break
  sleep 2
done
docker compose exec -T postgres sh -c 'pg_restore -U "$POSTGRES_USER" -d "$POSTGRES_DB" --clean --if-exists --no-owner' \
  < "$RESTORE_DATA_DIR/db.dump"
# Verificación: la DB no quedó vacía (sh -c con dobles comillas; $VAR del contenedor con \$)
N=$(docker compose exec -T postgres sh -c "psql -U \$POSTGRES_USER -d \$POSTGRES_DB -tAc \"SELECT count(*) FROM information_schema.tables WHERE table_schema='public'\"")
echo "tablas restauradas: $N"
test "$N" -gt 0
]]></field>
