        <field name="source_url">https://github.com/useplunk/plunk</field>
        <field name="docker_compose_template"><![CDATA[services:
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB: plunk
      POSTGRES_USER: plunk
      POSTGRES_PASSWORD: {{ db_password }}
    volumes:
    - ./postgres_data:/var/lib/postgresql/data
    healthcheck:
      test:
      - CMD-SHELL
      - pg_isready -U plunk
      interval: 10s
      timeout: 5s
      retries: 5
    container_name: '{{ INSTANCE_CODE }}_postgres'
    networks:
    - internal
  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: redis-server --appendonly yes
    volumes:
    - ./redis_data:/data
    healthcheck:
      test:
      - CMD
      - redis-cli
      - ping
      interval: 10s
      timeout: 5s
      retries: 5
    container_name: '{{ INSTANCE_CODE }}_redis'
    networks:
    - internal
  minio:
    image: minio/minio:latest
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: {{ minio_root_user }}
      MINIO_ROOT_PASSWORD: {{ minio_root_password }}
    volumes:
    - ./minio_data:/data
    ports:
    - 9000
    - 9001
    healthcheck:
      test:
      - CMD
      - curl
      - -f
      - http://localhost:9000/minio/health/live
      interval: 30s
      timeout: 20s
      retries: 3
    container_name: '{{ INSTANCE_CODE }}_minio'
    networks:
    - internal
  plunk:
    image: ghcr.io/useplunk/plunk:latest
    restart: unless-stopped
    environment:
      SERVICE: all
      NODE_ENV: production
      DATABASE_URL: postgresql://plunk:{{ db_password }}@postgres:5432/plunk
      DIRECT_DATABASE_URL: postgresql://plunk:{{ db_password }}@postgres:5432/plunk
      REDIS_URL: {{ redis_url }}
      JWT_SECRET: {{ jwt_secret }}
      NGINX_PORT: {{ nginx_port }}
      API_DOMAIN: {{ api_domain }}
      DASHBOARD_DOMAIN: {{ dashboard_domain }}
      LANDING_DOMAIN: {{ landing_domain }}
      WIKI_DOMAIN: {{ wiki_domain }}
      USE_HTTPS: {{ use_https }}
      AWS_SES_REGION: {{ aws_ses_region }}
      AWS_SES_ACCESS_KEY_ID: {{ aws_ses_access_key_id }}
      AWS_SES_SECRET_ACCESS_KEY: {{ aws_ses_secret_access_key }}
      SES_CONFIGURATION_SET: {{ ses_configuration_set }}
      SES_CONFIGURATION_SET_NO_TRACKING: ${SES_CONFIGURATION_SET_NO_TRACKING}
      GITHUB_OAUTH_CLIENT: {{ github_oauth_client }}
      GITHUB_OAUTH_SECRET: {{ github_oauth_secret }}
      GOOGLE_OAUTH_CLIENT: {{ google_oauth_client }}
      GOOGLE_OAUTH_SECRET: {{ google_oauth_secret }}
      STRIPE_SK: {{ stripe_sk }}
      STRIPE_WEBHOOK_SECRET: {{ stripe_webhook_secret }}
      STRIPE_PRICE_ONBOARDING: {{ stripe_price_onboarding }}
      STRIPE_PRICE_EMAIL_USAGE: {{ stripe_price_email_usage }}
      STRIPE_METER_EVENT_NAME: {{ stripe_meter_event_name }}
      S3_ENDPOINT: {{ s3_endpoint }}
      S3_ACCESS_KEY_ID: {{ s3_access_key_id }}
      S3_ACCESS_KEY_SECRET: {{ s3_access_key_secret }}
      S3_BUCKET: {{ s3_bucket }}
      S3_PUBLIC_URL: {{ s3_public_url }}
      S3_FORCE_PATH_STYLE: {{ s3_force_path_style }}
      SMTP_DOMAIN: {{ smtp_domain }}
      PORT_SECURE: {{ port_secure }}
      PORT_SUBMISSION: {{ port_submission }}
      PLUNK_API_KEY: {{ plunk_api_key }}
      PLUNK_FROM_ADDRESS: {{ plunk_from_address }}
    volumes:
    - /etc/dokploy/traefik/dynamic/acme.json:/certs/acme.json:ro
    ports:
    - '{{ PORT_HTTP }}:80'
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      minio:
        condition: service_healthy
    healthcheck:
      test:
      - CMD
      - curl
      - -f
      - http://localhost:80/
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    container_name: '{{ INSTANCE_CODE }}'
    networks:
    - internal
    - agz-proxy-network
networks:
  internal:
    driver: bridge
  agz-proxy-network:
    external: true
]]></field>
        <field name="backup_script"><![CDATA[#!/bin/bash
set -euo pipefail
cd "$SERVICE_PATH"
# Dump consistente de PostgreSQL (servicio en marcha) → $BACKUP_DATA_DIR
docker compose exec -T postgres sh -c 'pg_dump -U "$POSTGRES_USER" -d "$POSTGRES_DB" --no-owner -Fc' \
  > "$BACKUP_DATA_DIR/db.dump"
echo "pg_dump OK ($(wc -c < "$BACKUP_DATA_DIR/db.dump") bytes)"
]]></field>
        <field name="restore_script"><![CDATA[#!/bin/bash
set -euo pipefail
cd "$SERVICE_PATH"
# Levanta solo la DB, espera readiness y restaura
docker compose up -d postgres
for i in $(seq 1 30); do
  docker compose exec -T postgres sh -c 'pg_isready -U "$POSTGRES_USER"' && break
  sleep 2
done
docker compose exec -T postgres sh -c 'pg_restore -U "$POSTGRES_USER" -d "$POSTGRES_DB" --clean --if-exists --no-owner' \
  < "$RESTORE_DATA_DIR/db.dump"
# Verificación: la DB no quedó vacía (sh -c con dobles comillas; $VAR del contenedor con \$)
N=$(docker compose exec -T postgres sh -c "psql -U \$POSTGRES_USER -d \$POSTGRES_DB -tAc \"SELECT count(*) FROM information_schema.tables WHERE table_schema='public'\"")
echo "tablas restauradas: $N"
test "$N" -gt 0
]]></field>
