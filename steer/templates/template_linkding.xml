<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================
         REVISAR antes de publicar (heurísticas inciertas):
           - Owner UID:GID de 'linkding' (imagen sissbruecker/linkding:latest) desconocido → DEFAULT 1000:1000, verificar.
           - Imagen en 'latest': fijá un tag estable (variable selection) antes de producción.
         Validá con el botón «Validar» y el procedimiento E2E de la guía §6.
    ======================================================== -->
    <record id="template_linkding" model="service.template">
        <field name="name">Linkding</field>
        <field name="code">linkding</field>
        <field name="service_code">linkding</field>
        <field name="version">latest</field>
        <field name="description">Linkding is a minimal, fast, self-hosted bookmark manager that gives you full ownership of your links and reading list.</field>
        <field name="rich_description"><![CDATA[<div class="agz-app-desc">
  <p class="agz-app-lead">Linkding is a minimal, fast, self-hosted bookmark manager that gives you full ownership of your links and reading list.</p>
  <p>Built on Django, Linkding stores and organizes web bookmarks with a clean, distraction-free interface optimized for quickly adding and finding links. It automatically fetches titles, descriptions, icons and preview images, supports tag-based organization with bulk editing, and can keep snapshots of saved pages. It is a strong choice for anyone migrating away from hosted services like Pocket who wants a lightweight, privacy-respecting alternative.</p>
  <h6 class="agz-app-subhead">Key features</h6>
  <ul class="agz-app-feats">
    <li>Tag-based organization with bulk editing, Markdown notes and read-it-later workflow</li>
    <li>Automatic retrieval of page titles, descriptions, icons and preview images</li>
    <li>Website archiving as local HTML snapshots or via the Internet Archive</li>
    <li>Multi-user support with bookmark sharing to other users or public guests</li>
    <li>Netscape HTML import/export, REST API, browser extensions and a bookmarklet</li>
    <li>Installable as a PWA; SSO via OIDC or authentication proxies</li>
  </ul>
  <h6 class="agz-app-subhead">Best for</h6>
  <p>Individuals, teams and homelab users who want a simple, resource-light, fully self-hosted way to collect, tag and search their bookmarks without relying on third-party cloud services.</p>
</div>]]></field>
        <field name="category">knowledge</field>
        <field name="is_web_app">True</field>
        <field name="requires_database">False</field>
        <field name="requires_backup">True</field>
        <field name="backup_mode">standard</field>
        <field name="image" type="base64" file="agz_infra_templates/static/img/templates/linkding.png"/>
        <field name="tag_ids" eval="[Command.set([ref('agz_infra_suite.tag_self_hosted'), ref('agz_infra_suite.tag_productivity'), ref('agz_infra_suite.tag_documentation'), ref('agz_infra_suite.tag_search'), ref('agz_infra_suite.tag_privacy'), ref('agz_infra_suite.tag_bookmarks')])]"/>
        <field name="website_url">https://linkding.link/</field>
        <field name="documentation_url">https://github.com/sissbruecker/linkding/tree/master/docs</field>
        <field name="source_url">https://github.com/sissbruecker/linkding</field>
        <field name="docker_compose_template"><![CDATA[services:
  linkding:
    image: sissbruecker/linkding:latest
    restart: unless-stopped
    ports:
    - '{{ PORT_HTTP }}:9090'
    volumes:
    - ../files/linkding-data:/etc/linkding/data
    container_name: '{{ INSTANCE_CODE }}'
    networks:
    - internal
    - agz-proxy-network
networks:
  internal:
    driver: bridge
  agz-proxy-network:
    external: true
]]></field>
    </record>
