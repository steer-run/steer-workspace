<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================
         REVISAR antes de publicar (heurísticas inciertas):
           - Owner UID:GID de 'freshrss' (imagen freshrss/freshrss:${FRESHRSS_VERSION:-latest}) desconocido → DEFAULT 1000:1000, verificar.
           - Sin servicio de DB: si la app usa SQLite, pasá backup_mode=custom con `sqlite3 .backup` y exclude_from_backup en el volumen del .db.
           - Imagen en 'latest': fijá un tag estable (variable selection) antes de producción.
         Validá con el botón «Validar» y el procedimiento E2E de la guía §6.
    ======================================================== -->
    <record id="template_freshrss" model="service.template">
        <field name="name">FreshRSS</field>
        <field name="code">freshrss</field>
        <field name="service_code">freshrss</field>
        <field name="version">latest</field>
        <field name="description">FreshRSS is a fast, self-hosted RSS and Atom feed aggregator that puts you back in control of the news, blogs, podcasts and video channels you follow.</field>
        <field name="rich_description"><![CDATA[<div class="agz-app-desc">
  <p class="agz-app-lead">FreshRSS is a fast, self-hosted RSS and Atom feed aggregator that puts you back in control of the news, blogs, podcasts and video channels you follow.</p>
  <p>It collects content from thousands of sources into a single private reader, with multi-user support, custom tags, saved searches and per-user feeds. Lightweight enough to run on a Raspberry Pi yet able to scale to 50,000+ feeds and over a million articles, it is built for individuals, families and teams who want an ad-free, tracker-free alternative to commercial news readers. Native mobile and desktop apps connect through its Google Reader and Fever APIs.</p>
  <h6 class="agz-app-subhead">Key features</h6>
  <ul class="agz-app-feats">
    <li>Aggregate RSS/Atom feeds, podcasts and video channels with OPML import/export</li>
    <li>Multi-user accounts with custom tags, filters, saved searches and an anonymous reading mode</li>
    <li>Web scraping (XPath) and JSON support to build feeds for sites that offer none</li>
    <li>Real-time push via WebSub, plus a CLI and a client API (Google Reader / Fever)</li>
    <li>Flexible authentication: web form, HTTP Auth (proxy-friendly) and OpenID Connect</li>
    <li>Themes and extensions for deep customization</li>
  </ul>
  <h6 class="agz-app-subhead">Best for</h6>
  <p>Privacy-conscious individuals, families and teams who want a self-hosted, ad-free news reader that scales from a Raspberry Pi to large multi-user deployments and works with their favorite native apps.</p>
</div>]]></field>
        <field name="category">media</field>
        <field name="is_web_app">True</field>
        <field name="requires_database">False</field>
        <field name="requires_backup">True</field>
        <field name="backup_mode">standard</field>
        <field name="image" type="base64" file="agz_infra_templates/static/img/templates/freshrss.png"/>
        <field name="tag_ids" eval="[Command.set([ref('agz_infra_suite.tag_self_hosted'), ref('agz_infra_suite.tag_media'), ref('agz_infra_suite.tag_privacy'), ref('agz_infra_suite.tag_search'), ref('agz_infra_suite.tag_rss')])]"/>
        <field name="website_url">https://freshrss.org/</field>
        <field name="documentation_url">https://freshrss.github.io/FreshRSS/</field>
        <field name="source_url">https://github.com/FreshRSS/FreshRSS</field>
        <field name="docker_compose_template"><![CDATA[services:
  freshrss:
    image: freshrss/freshrss:${FRESHRSS_VERSION:-latest}
    restart: unless-stopped
    volumes:
    - ./freshrss_data:/var/www/FreshRSS/data
    - ./freshrss_extensions:/var/www/FreshRSS/extensions
    ports:
    - '{{ PORT_HTTP }}:80'
    environment:
      TZ: ${TZ:-UTC}
      CRON_MIN: ${CRON_MIN:-13,43}
      FRESHRSS_ENV: ${FRESHRSS_ENV:-production}
      COPY_LOG_TO_SYSLOG: ${COPY_LOG_TO_SYSLOG:-On}
      COPY_SYSLOG_TO_STDERR: ${COPY_SYSLOG_TO_STDERR:-On}
      FRESHRSS_INSTALL: ${FRESHRSS_INSTALL:-}
      FRESHRSS_USER: ${FRESHRSS_USER:-}
    container_name: '{{ INSTANCE_CODE }}'
    networks:
    - internal
    - agz-proxy-network
networks:
  internal:
    driver: bridge
  agz-proxy-network:
    external: true
]]></field>
    </record>
    <record id="template_freshrss_port_http" model="service.template.port">
        <field name="template_id" ref="template_freshrss"/>
        <field name="code">http</field>
        <field name="name">HTTP</field>
        <field name="default_port">80</field>
        <field name="traefik_routed">True</field>
        <field name="sequence">10</field>
    </record>
    <record id="template_freshrss_var_timezone" model="service.template.variable">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">timezone</field>
        <field name="var_type">string</field>
        <field name="sequence">10</field>
    </record>
    <record id="template_freshrss_var_freshrss_version" model="service.template.variable">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">freshrss_version</field>
        <field name="var_type">string</field>
        <field name="default_value">latest</field>
        <field name="sequence">20</field>
    </record>
    <record id="template_freshrss_var_cron_min" model="service.template.variable">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">cron_min</field>
        <field name="var_type">string</field>
        <field name="default_value">13,43</field>
        <field name="sequence">30</field>
    </record>
    <record id="template_freshrss_var_freshrss_env" model="service.template.variable">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">freshrss_env</field>
        <field name="var_type">string</field>
        <field name="default_value">production</field>
        <field name="sequence">40</field>
    </record>
    <record id="template_freshrss_var_copy_log_to_syslog" model="service.template.variable">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">copy_log_to_syslog</field>
        <field name="var_type">string</field>
        <field name="default_value">On</field>
        <field name="sequence">50</field>
    </record>
    <record id="template_freshrss_var_copy_syslog_to_stderr" model="service.template.variable">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">copy_syslog_to_stderr</field>
        <field name="var_type">string</field>
        <field name="default_value">On</field>
        <field name="sequence">60</field>
    </record>
    <record id="template_freshrss_vol_0" model="service.template.volume">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">freshrss_data</field>
        <field name="local_path">./freshrss_data</field>
        <field name="owner">1000:1000</field>
        <field name="exclude_from_backup">False</field>
        <field name="sequence">10</field>
    </record>
    <record id="template_freshrss_vol_1" model="service.template.volume">
        <field name="template_id" ref="template_freshrss"/>
        <field name="name">freshrss_extensions</field>
        <field name="local_path">./freshrss_extensions</field>
        <field name="owner">1000:1000</field>
        <field name="exclude_from_backup">False</field>
        <field name="sequence">20</field>
    </record>
</odoo>
