<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================================
         REVISAR antes de publicar (heurísticas inciertas):
           - Multi-servicio (además de 'hoppscotch': migrate): revisar backup/red/init.
           - Owner UID:GID de 'hoppscotch' (imagen hoppscotch/hoppscotch:latest) desconocido → DEFAULT 1000:1000, verificar.
           - Imagen en 'latest': fijá un tag estable (variable selection) antes de producción.
         Validá con el botón «Validar» y el procedimiento E2E de la guía §6.
    ======================================================== -->
    <record id="template_hoppscotch" model="service.template">
        <field name="name">Hoppscotch (AIO + Migrations)</field>
        <field name="code">hoppscotch</field>
        <field name="service_code">hoppscotch</field>
        <field name="version">latest</field>
        <field name="description">Hoppscotch is a fast, open-source API development ecosystem and a self-hostable alternative to Postman and Insomnia.</field>
        <field name="rich_description"><![CDATA[<div class="agz-app-desc">
  <p class="agz-app-lead">Hoppscotch is a fast, open-source API development ecosystem and a self-hostable alternative to Postman and Insomnia.</p>
  <p>It provides a minimalist web client for designing, sending, testing and debugging API requests across HTTP, GraphQL, WebSocket, Socket.IO, MQTT and Server-Sent Events. The self-hosted Community Edition ships as an all-in-one deployment (frontend, backend and admin dashboard) backed by PostgreSQL, giving teams full data ownership on their own infrastructure. It is aimed at developers and teams who want collaborative API tooling without sending requests or credentials through a third-party cloud.</p>
  <h6 class="agz-app-subhead">Key features</h6>
  <ul class="agz-app-feats">
    <li>Multi-protocol clients: HTTP/REST, GraphQL, WebSocket, Socket.IO, MQTT and Server-Sent Events</li>
    <li>Collections, folders and request history to organize and reuse API calls</li>
    <li>Environments and variables for managing base URLs, tokens and per-stage configuration</li>
    <li>Pre-request scripts, test scripts and code-snippet generation for many languages</li>
    <li>Team workspaces with real-time collaboration and shared collections</li>
    <li>Admin dashboard for users and workspaces, plus a built-in proxy to bypass browser CORS limits</li>
  </ul>
  <h6 class="agz-app-subhead">Best for</h6>
  <p>Developers, QA engineers and teams that want a private, self-hosted API client and testing platform with full control over data, ideal for organizations replacing cloud-based tools like Postman.</p>
</div>]]></field>
        <field name="category">dev_tools</field>
        <field name="is_web_app">True</field>
        <field name="requires_database">True</field>
        <field name="database_type">postgres</field>
        <field name="requires_backup">True</field>
        <field name="backup_mode">custom</field>
        <field name="health_check_command">pg_isready -U $POSTGRES_USER</field>
        <field name="image" type="base64" file="agz_infra_templates/static/img/templates/hoppscotch.png"/>
        <field name="tag_ids" eval="[Command.set([ref('agz_infra_suite.tag_self_hosted'), ref('agz_infra_suite.tag_dev_tools'), ref('agz_infra_suite.tag_collaboration'), ref('agz_infra_suite.tag_productivity')])]"/>
        <field name="website_url">https://hoppscotch.io/</field>
        <field name="documentation_url">https://docs.hoppscotch.io/documentation/self-host/community-edition/install-and-build</field>
        <field name="source_url">https://github.com/hoppscotch/hoppscotch</field>
        <field name="docker_compose_template"><![CDATA[services:
  hoppscotch:
    image: hoppscotch/hoppscotch:latest
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      migrate:
        condition: service_completed_successfully
    expose:
    - 80
    environment:
      DATABASE_URL: {{ database_url }}
      DATA_ENCRYPTION_KEY: {{ data_encryption_key }}
      HOPP_AIO_ALTERNATE_PORT: {{ hopp_aio_alternate_port }}
      WHITELISTED_ORIGINS: {{ whitelisted_origins }}
      VITE_BASE_URL: {{ vite_base_url }}
      VITE_SHORTCODE_BASE_URL: {{ vite_shortcode_base_url }}
      VITE_ADMIN_URL: {{ vite_admin_url }}
      VITE_BACKEND_GQL_URL: {{ vite_backend_gql_url }}
      VITE_BACKEND_WS_URL: {{ vite_backend_ws_url }}
      VITE_BACKEND_API_URL: {{ vite_backend_api_url }}
      VITE_APP_TOS_LINK: {{ vite_app_tos_link }}
      VITE_APP_PRIVACY_POLICY_LINK: {{ vite_app_privacy_policy_link }}
      ENABLE_SUBPATH_BASED_ACCESS: 'true'
    volumes:
    - ./hoppscotch_data:/app/data
    container_name: '{{ INSTANCE_CODE }}'
    ports:
    - '{{ PORT_HTTP }}:80'
    networks:
    - internal
    - agz-proxy-network
  postgres:
    image: postgres:16
    restart: unless-stopped
    expose:
    - 5432
    environment:
      POSTGRES_DB: {{ postgres_db }}
      POSTGRES_USER: {{ postgres_user }}
      POSTGRES_PASSWORD: {{ postgres_password }}
    volumes:
    - ./hoppscotch_postgres:/var/lib/postgresql/data
    healthcheck:
      test:
      - CMD-SHELL
      - pg_isready -U {{ postgres_user }} -d {{ postgres_db }}
      interval: 10s
      timeout: 5s
      retries: 5
    container_name: '{{ INSTANCE_CODE }}_postgres'
    networks:
    - internal
  migrate:
    image: hoppscotch/hoppscotch:latest
    depends_on:
      postgres:
        condition: service_healthy
    entrypoint:
    - /bin/sh
    - -c
    command:
    - 'echo "Running database migrations..."

      pnpm dlx prisma migrate deploy && echo "Migration complete!"

      '
    environment:
      DATABASE_URL: {{ database_url }}
    restart: 'no'
    container_name: '{{ INSTANCE_CODE }}_migrate'
    networks:
    - internal
networks:
  internal:
    driver: bridge
  agz-proxy-network:
    external: true
]]></field>
        <field name="backup_script"><![CDATA[#!/bin/bash
set -euo pipefail
cd "$SERVICE_PATH"
# Dump consistente de PostgreSQL (servicio en marcha) → $BACKUP_DATA_DIR
docker compose exec -T postgres sh -c 'pg_dump -U "$POSTGRES_USER" -d "$POSTGRES_DB" --no-owner -Fc' \
  > "$BACKUP_DATA_DIR/db.dump"
echo "pg_dump OK ($(wc -c < "$BACKUP_DATA_DIR/db.dump") bytes)"
]]></field>
        <field name="restore_script"><![CDATA[#!/bin/bash
set -euo pipefail
cd "$SERVICE_PATH"
# Levanta solo la DB, espera readiness y restaura
docker compose up -d postgres
for i in $(seq 1 30); do
  docker compose exec -T postgres sh -c 'pg_isready -U "$POSTGRES_USER"' && break
  sleep 2
done
docker compose exec -T postgres sh -c 'pg_restore -U "$POSTGRES_USER" -d "$POSTGRES_DB" --clean --if-exists --no-owner' \
  < "$RESTORE_DATA_DIR/db.dump"
# Verificación: la DB no quedó vacía (sh -c con dobles comillas; $VAR del contenedor con \$)
N=$(docker compose exec -T postgres sh -c "psql -U \$POSTGRES_USER -d \$POSTGRES_DB -tAc \"SELECT count(*) FROM information_schema.tables WHERE table_schema='public'\"")
echo "tablas restauradas: $N"
test "$N" -gt 0
]]></field>
